<div class="row mb-2">
  <div class="col-2">
    <%= link_to "Back", products_path, class: "btn btn-secondary", role: "button" %>
  </div>
</div>
<div class="row">
  <div class="col-md-6">
    <% if @product.featured_image.attached? %>
      <%= image_tag @product.featured_image.variant(resize_to_limit: [600, 400]) %>
    <% else %>
      <%= image_tag "https://placehold.co/600x400" %>
    <% end %>
  </div>
  <div class="col-md-6">
    <% cache @product do %>
      <h1><%= @product.name %></h1>
      <%= @product.description %>
    <% end %>
  </div>
</div>
<% if authenticated? %>
  <div class="row">
    <div class="col-1">
      <%= link_to "Edit", edit_product_path(@product), class: "btn btn-warning", role: "button" %>
    </div>
    <div class="col-1">
      <%= button_to "Delete", @product, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-danger" %>
    </div>
  </div>
<% end %>