<% cache @product do %>
  <h1><%= @product.name %></h1>
<% end %>

<%= link_to "Back", products_path, class: "btn btn-secondary", role: "button" %>
<% if authenticated? %>
  <%= link_to "Edit", edit_product_path(@product), class: "btn btn-warning", role: "button" %>
  <%= button_to "Delete", @product, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-danger" %>
<% end %>