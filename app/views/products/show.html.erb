<div class="container py-4">

  <!-- Back button -->
  <div class="mb-3">
    <%= link_to "Back to products",
        products_path,
        class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <!-- Product -->
  <div class="row">

    <!-- Image -->
    <div class="col-12 col-md-6">
      <div class="card shadow-sm border-0">
        <% if @product.featured_image.attached? %>
          <%= image_tag @product.featured_image.variant(resize_to_limit: [800, 600]),
              class: "card-img-top img-fluid rounded" %>
        <% else %>
          <%= image_tag "https://placehold.co/800x600",
              class: "card-img-top img-fluid rounded" %>
        <% end %>
      </div>
    </div>

    <!-- Info -->
    <div class="col-12 col-md-6">
      <div class="d-flex flex-column">
        <% cache @product do %>
          <h1 class="mb-3"><%= @product.name %></h1>
          <p class="text-muted">
            <%= @product.description %>
          </p>
          <div class="mb-3">
            <span class="badge bg-info text-dark">
              Inventory: <%= @product.inventory_count %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

</div>