<div class="row justify-content-center px-6 py-5">
  <div class="col-6">
    <div class="card rounded shadow">
      <div class="card-header text-center">
        <h1>Rails Store</h1>
      </div>
      <card class="card-body">
        <%= form_with url: session_path do |form| %>
          <div class="mb-3">
            <%= form.label :email_address, class: "form-label" %>
            <%= form.email_field :email_address, required: true, autocomplete: "email", value: params[:email_address], class: "form-control", placeholder: "nome@email.com" %>
          </div>
          <div class="mb-3">
            <%= form.label :password, class: "form-label" %>
            <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72, class: "form-control", placeholder: "••••••••" %>
          </div>
          <div class="d-grid">
            <%= form.submit "Login", class: "btn btn-primary btn-lg" %>
          </div>
        <% end %>
        <br>
        <%= link_to "Forgot password?", new_password_path %>
      </card>
    </div>
  </div>
</div>