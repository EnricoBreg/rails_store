<div class="row">
  <h1><%= pluralize @subscribers.count, "Subscriber" %></h1>
</div>
<div class="row">
  <%= form_with url: store_subscribers_path, method: :get do |form| %>
    <div class="row mb-3">
      <div class="col-12 col-md-3">
        <%= form.collection_select :product_id, Product.all, :id, :name, { selected: params[:product_id], include_blank: "All Products" }, class: "form-select" %>
      </div>
      <div class="col-12 col-md-4">
        <%= form.submit "Filter", class: "btn btn-secondary" %>
      </div>
    </div>
  <% end %>
</div>
<div class="row">
  <%= render "subscribers", subscribers: @subscribers %>
</div>