<div class="row mb-5">
  <div class="col">
    <%= link_to "Back to users", store_users_path, class: "btn btn-secondary" %>
  </div>
</div>
<div class="row mb-5">
  Full name: <strong><%= @user.full_name %></strong>
  Email address: <strong><%= @user.email_address %></strong>
</div>
<div class="row">
  <div class="d-flex justify-content-start gap-2">
    <%= link_to "Edit user", edit_store_user_path(@user), class: "btn btn-primary" %>
    <%= button_to "Delete user", store_user_path(@user), class: "btn btn-danger", method: :delete, data: {
      turbo_confirm: "Are you sure you want to delete this user? This action cannot be undone."
    } %>
  </div>
</div>