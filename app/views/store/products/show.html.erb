<div class="container py-4">
  <!-- Back button -->
  <div class="mb-3">
    <%= link_to "Back to products",
        store_products_path,
        class: "btn btn-outline-secondary btn-sm" %>
  </div>
  <!-- Product -->
  <div class="row mb-4">
    <!-- Image -->
    <div class="col-12 col-md-6">
      <div class="card shadow-sm border-0">
        <% if @product.featured_image.attached? %>
          <%= image_tag @product.featured_image.variant(resize_to_limit: [800, 600]),
              class: "card-img-top img-fluid rounded" %>
        <% else %>
          <%= image_tag "https://placehold.co/800x600",
              class: "card-img-top img-fluid rounded" %>
        <% end %>
      </div>
    </div>
    <!-- Info -->
    <div class="col-12 col-md-6 d-flex flex-column">
      <% cache @product do %>
        <h1 class="mb-3"><%= @product.name %></h1>
        <p class="text-muted">
          <%= @product.description %>
        </p>
        <div class="mb-3">
          <span class="badge bg-info text-dark">
            Inventory: <%= @product.inventory_count %>
          </span>
        </div>
      <% end %>
      <!-- Actions -->
      <% if authenticated? %>
        <div class="mt-auto pt-3 border-top d-flex gap-2">
          <%= link_to "Edit",
              edit_store_product_path(@product),
              class: "btn btn-warning" %>
          <%= button_to "Delete",
              @product,
              method: :delete,
              data: { turbo_confirm: "Are you sure?" },
              class: "btn btn-danger" %>
        </div>
      <% end %>
    </div>
  </div>
  <div class="row">
    <div class="col-12 col-md-6 mb-2">
      <div class="card">
        <div class="card-body d-flex justify-content-between align-items-center">
          <p class="h5">Appears in <%= pluralize(@product.wishlists_count, "wishlist") %></p>
          <%= link_to "Go", store_wishlists_path(product_id: @product), class: "btn btn-outline-primary" %>
        </div>
      </div>
    </div>
    <div class="col-12 col-md-6">
      <div class="card">
        <div class="card-body d-flex justify-content-between align-items-center">
          <p class="h5">Counts <%= pluralize(@product.subscribers.count, "subscribers") %></p>
          <%= link_to "Go", store_subscribers_path(product_id: @product), class: "btn btn-outline-primary" %>
        </div>
      </div>
    </div>
  </div>
</div>