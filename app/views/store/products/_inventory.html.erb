<% if product.inventory_count.positive? %>
  <p><%= product.inventory_count %> in stock</p>
<% else %>
  <p>Out of stock</p>
  <p>Email me when available.</p>
  <%= form_with model: [product, Subscriber.new] do |form| %>
    <div class="mb-3">
      <%= form.email_field :email, placeholder: "you@example.com", required: true, class: "form-control" %>
    </div>
    <div><%= form.submit "Notify me", class: "btn btn-primary btn-small" %></div>
  <% end %>
<% end %>