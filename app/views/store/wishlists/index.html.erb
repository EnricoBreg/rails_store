<div class="row">
  <div class="col-12">
    <h1><%= pluralize @wishlists.count, "Wishlist" %></h1>
  </div>
</div>
<%= form_with url: store_wishlists_path, method: :get do |form| %>
  <div class="row mb-3">
    <div class="col-12 col-md-3">
      <%= form.collection_select :user_id, User.all, :id, :full_name, { selected: params[:user_id], include_blank: "All users" }, class: "form-select" %>
    </div>
    <div class="col-12 col-md-3">
      <%= form.collection_select :product_id, Product.all, :id, :name, { selected: params[:product_id], include_blank: "All Products" }, class: "form-select" %>
    </div>
    <div class="col-12 col-md-4">
      <%= form.submit "Filter", class: "btn btn-secondary" %>
    </div>
  </div>
<% end %>
<div class="row">
  <%= render "wishlists", wishlists: @wishlists %>
</div>